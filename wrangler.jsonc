{
  "name": "discoverse",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-25",
  "compatibility_flags": ["nodejs_compat"],
  "assets": { "directory": ".open-next/assets", "binding": "ASSETS" },

  // ⬇️ No "routes" at the root for dev
  "env": {
    "production": {
      "routes": [
        { "pattern": "discoverse.co.uk", "custom_domain": true },
        { "pattern": "www.discoverse.co.uk", "custom_domain": true }
      ]
    }
  }
}
