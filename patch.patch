+  // --- Kinetic pan listeners & fling loop ---
+  useEffect(() => {
+    const fg = graphRef.current;
+    // Prefer the actual canvas element if available
+    const el: HTMLElement | null =
+      (fg && (fg as any).canvas && (fg as any).canvas()) || containerRef.current;
+    if (!el || !fg) return;
+
+    const k = kineticRef.current;
+
+    const onPointerDown = () => {
+      // Any new interaction cancels inertia immediately
+      stopKinetic();
+      k.lastPts = [];
