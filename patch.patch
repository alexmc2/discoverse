+
+    const onPointerMove = (ev: PointerEvent | MouseEvent | TouchEvent) => {
+      // Sample the last ~120ms of positions to estimate release velocity
+      let x = 0,
+        y = 0;
+      const now = performance.now();
+
+      if ((ev as TouchEvent).touches && (ev as TouchEvent).touches.length) {
+        const t = (ev as TouchEvent).touches[0];
+        x = t.clientX;
+        y = t.clientY;
+      } else if ((ev as PointerEvent).clientX != null) {
+        const p = ev as PointerEvent;
+        x = p.clientX;
+        y = p.clientY;
+      } else {
+        const m = ev as MouseEvent;
+        x = m.clientX;
+        y = m.clientY;
+      }
+
+      k.lastPts.push({ x, y, t: now });
+      const cutoff = now - 120;
+      while (k.lastPts.length && k.lastPts[0].t < cutoff) k.lastPts.shift();
+    };
+
+    const onPointerUp = () => {
+      if (k.lastPts.length < 2) return;
+      const a = k.lastPts[0];
+      const b = k.lastPts[k.lastPts.length - 1];
+      const dt = Math.max(1, b.t - a.t);
+      const vxPx = (b.x - a.x) / dt; // px/ms
+      const vyPx = (b.y - a.y) / dt; // px/ms
+
+      // Ignore micro flicks / taps
+      const speed = Math.hypot(vxPx, vyPx);
+      if (speed < 0.05) {
+        k.lastPts = [];
+        return;
+      }
+
+      // Convert pixel velocity to graph-space velocity using current zoom
+      const screenCenterX = dimensions.width / 2;
+      const screenCenterY = dimensions.height / 2;
+      const centerA = fg.screen2GraphCoords(screenCenterX, screenCenterY);
+      const centerAXp = fg.screen2GraphCoords(screenCenterX + 1, screenCenterY + 1);
+
+      const pxToGraphX = centerAXp.x - centerA.x;
+      const pxToGraphY = centerAXp.y - centerA.y;
+
+      k.vx = -vxPx * pxToGraphX; // world moves opposite the drag
+      k.vy = -vyPx * pxToGraphY;
+      k.active = true;
+
